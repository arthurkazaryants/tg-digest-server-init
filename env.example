# Сервер
SERVER_HOSTNAME=my-server
TIMEZONE=Europe/Moscow

# Пользователь
NEW_USER=deploy
NEW_USER_SHELL=/bin/bash
NEW_USER_HOME=/home/deploy

# SSH
SSH_PORT=2222
SSH_PUBLIC_KEY=ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAAB... user@local

# UFW и доступ
ENABLE_UFW=true
ALLOW_USERS=deploy root

# Включение компонентов
ENABLE_FAIL2BAN=true
ENABLE_DOCKER=true
ENABLE_UNATTENDED_UPGRADES=true
ENABLE_SWAP=true
SWAP_SIZE_GB=2

# ВАЖНО: Флаги безопасности - изменяй только после понимания риска
APPLY_SSH_CHANGES=false
FINALIZE_FIREWALL=false

# Параметры для bootstrap-remote.sh
REMOTE_ROOT_USER=root
REMOTE_ROOT_PORT=22
REMOTE_HOST=192.168.1.100
REMOTE_DEPLOY_DIR=/opt/server-bootstrap

# Дополнительно
JOURNALD_MAX_SIZE=1G
JOURNALD_MAX_RETENTION=14d
